{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/core-application/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ruff libs/core-application/src"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mypy libs/core-application/src"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pytest libs/core-application/src"
      }
    }
  },
  "tags": [
    "core",
    "layer:application"
  ]
}