{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/core-api",
  "targets": {
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uvicorn apps/core-api.main:app --reload"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ruff apps/core-api"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mypy apps/core-api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pytest apps/core-api"
      }
    }
  },
  "tags": [
    "core",
    "layer:api"
  ]
}