{
  "$schema": "node_modules/nx/schemas/nx-schema.json",
  "npmScope": "HomeStation_Core",
  "affected": {
    "defaultBase": "main"
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "nx/task-runners/default",
      "options": {
        "cacheableOperations": ["lint", "test", "typecheck"],
        "parallel": 3
      }
    }
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  }
}