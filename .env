# Example environment variables for HomeStation_Core

# Database connection string (e.g. for Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/HomeStation_Core

# Secret key for JWT or session signing
SECRET_KEY=please-change-me

# Event bus broker URL (RabbitMQ/Aio‑Pika)
EVENT_BUS_URL=amqp://guest:guest@localhost/